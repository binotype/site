{
	"name": "@binotype/site",
	"version": "2.0.0-alpha.1",
	"description": "Stencil Component Starter",
	"main": "dist/index.cjs.js",
	"module": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"collection": "dist/collection/collection-manifest.json",
	"collection:main": "dist/collection/index.js",
	"unpkg": "dist/binotype/binotype.esm.js",
	"exports": {
		".": {
			"import": "./dist/binotype/binotype.esm.js",
			"require": "./dist/binotype/binotype.cjs.js"
		},
		"./test": {
			"import": "./dist/collection/components/Test.js",
			"types": "./dist/types/components/Test.d.ts"
		},
		"./my-component": {
			"import": "./dist/components/my-component.js",
			"types": "./dist/components/my-component.d.ts"
		},
		"./loader": {
			"import": "./loader/index.js",
			"require": "./loader/index.cjs",
			"types": "./loader/index.d.ts"
		}
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/binotype/site.git"
	},
	"bugs": {
		"url": "https://github.com/binotype/site/issues"
	},
	"homepage": "https://github.com/binotype/site",
	"files": [
		"dist/",
		"loader/"
	],
	"git": {
		"tagName": "release-${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"build": "stencil build",
		"start": "stencil build --dev --watch --serve",
		"test": "stencil-test --prod",
		"test:watch": "stencil-test --prod --watch",
		"generate": "stencil generate",
		"lint": "biome format .",
		"format": "biome format --write .",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run lint && npm run test && npm audit --omit=dev"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@stencil/core": "^4.27.1 || ^5.0.0-0",
		"@stencil/vitest": "^1.8.3",
		"@types/node": "^22.13.5",
		"@vitest/browser-playwright": "^4.0.0",
		"playwright": "^1.52.0",
		"rimraf": "6.1.3",
		"vitest": "^4.0.0"
	},
	"license": "MIT",
	"dependencies": {
		"@binotype/model": "^1.7.0"
	}
}
