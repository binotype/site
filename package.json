{
	"name": "@binotype/site",
	"version": "2.0.0-alpha.11",
	"description": "Stencil Component Starter",
	"main": "dist/index.cjs.js",
	"module": "dist/index.js",
	"types": "dist/types/index.d.ts",
	"collection": "dist/collection/collection-manifest.json",
	"collection:main": "dist/collection/index.js",
	"unpkg": "dist/binotype/binotype.esm.js",
	"exports": {
		".": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js"
		},
		"./parser": {
			"types": "./dist/types/index.d.ts",
			"import": "./dist/index.js"
		},
		"./components": {
			"import": "./dist/collection/components/index.js",
			"types": "./dist/types/components/index.d.ts"
		},
		"./components/*": {
			"import": "./dist/components/*.js",
			"types": "./dist/types/components/*.d.ts"
		},
		"./binotype-site": {
			"import": "./dist/components/binotype-site.js",
			"types": "./dist/components/binotype-site.d.ts"
		},
		"./loader": {
			"import": "./loader/index.js",
			"types": "./loader/index.d.ts"
		}
	},
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/binotype/site.git"
	},
	"bugs": {
		"url": "https://github.com/binotype/site/issues"
	},
	"homepage": "https://github.com/binotype/site",
	"files": [
		"dist/",
		"loader/"
	],
	"git": {
		"tagName": "release-${version}"
	},
	"github": {
		"release": true
	},
	"scripts": {
		"build": "stencil build",
		"start": "stencil build --dev --watch --serve",
		"test": "vitest --run --config vitest.config.ts",
		"coverage": "vitest --run --coverage --config vitest.config.ts",
		"test:watch": "vitest --config vitest.config.ts",
		"generate": "stencil generate",
		"lint": "biome format .",
		"format": "biome format --write .",
		"clean": "rimraf dist node_modules coverage",
		"verify": "npm run build && npm run lint && npm run test && npm audit --omit=dev"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@stencil/core": "^4.43.4",
		"@stencil/vitest": "^1.11.6",
		"@types/node": "^25.9.0",
		"@vitest/coverage-v8": "^4.1.7",
		"@vitest/browser-playwright": "^4.1.7",
		"playwright": "^1.60.0",
		"rimraf": "6.1.3",
		"vite": "^8.0.13",
		"vitest": "^4.1.7"
	},
	"license": "MIT",
	"dependencies": {
		"@typeup/dom": "1.0.11-beta.9",
		"@typeup/parser": "1.2.5-beta.9",
		"isly": "1.10.0",
		"isoly": "3.1.8",
		"tidily": "^0.2.7"
	}
}
